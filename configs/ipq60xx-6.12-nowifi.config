CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_zn-m2=y

CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_COMPRESSION_ZSTD=y

CONFIG_DEVEL=y
CONFIG_TOOLCHAINOPTS=y

CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -mcpu=cortex-a53"

CONFIG_BUSYBOX_CUSTOM=y

CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y

CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

CONFIG_PACKAGE_odhcpd-ipv6only=y

CONFIG_PACKAGE_iperf3=y

CONFIG_PACKAGE_irqbalance=y

CONFIG_PACKAGE_apk=y
CONFIG_PACKAGE_libapk=y

CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-conntrack6=y

CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y

CONFIG_PACKAGE_kmod-ppp=y
CONFIG_PACKAGE_kmod-pppoe=y
CONFIG_PACKAGE_kmod-slhc=y

CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_kmod-qca-nss-macsec=y


# 禁用 WiFi
CONFIG_PACKAGE_kmod-mac80211=n
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad=n
CONFIG_PACKAGE_hostapd=n


# 禁用 USB
CONFIG_PACKAGE_kmod-usb-core=n
CONFIG_PACKAGE_kmod-usb2=n
CONFIG_PACKAGE_kmod-usb3=n


# 禁用 VPN
CONFIG_PACKAGE_luci-app-wireguard=n
CONFIG_PACKAGE_wireguard-tools=n
CONFIG_PACKAGE_kmod-wireguard=n
CONFIG_PACKAGE_openvpn-openssl=n
CONFIG_PACKAGE_strongswan=n


# 禁用 Docker
CONFIG_PACKAGE_dockerd=n
CONFIG_PACKAGE_containerd=n
CONFIG_PACKAGE_runc=n